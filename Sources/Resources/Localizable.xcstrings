    "onboarding.step.automation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reads playback info from the Spotify desktop app via macOS Automation — no account login needed."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过 macOS 自动化功能读取 Spotify 桌面客户端的播放信息，无需登录账号。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "透過 macOS 自動化功能讀取 Spotify 桌面客戶端的播放資訊，無需登入帳號。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS オートメーションを通じて Spotify デスクトップアプリから再生情報を取得します。アカウントログインは不要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS 자동화를 통해 Spotify 데스크톱 앱에서 재생 정보를 읽습니다. 계정 로그인이 필요 없습니다."
          }
        }
      }
    },
    "onboarding.step.lyrics": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fetches synced lyrics from open sources (LRCLIB, Musixmatch, Soda Music)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从开放歌词源（LRCLIB、Musixmatch、汽水音乐）获取同步歌词。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從開放歌詞源（LRCLIB、Musixmatch、汽水音樂）取得同步歌詞。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オープンソース（LRCLIB、Musixmatch、Soda Music）から同期歌詞を取得します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오픈 소스(LRCLIB, Musixmatch, Soda Music)에서 싱크 가사를 가져옵니다."
          }
        }
      }
    },
    "onboarding.step.display": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Displays lyrics in a floating Dynamic Island at the top of your screen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在屏幕顶部以灵动岛的形式展示歌词。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在螢幕頂部以靈動島的形式顯示歌詞。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画面上部のフローティングダイナミックアイランドに歌詞を表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "화면 상단의 플로팅 다이나믹 아일랜드에 가사를 표시합니다."
          }
        }
      }
    },
    "onboarding.spotify_check": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Spotify Desktop App"
          }
        },
        "zh-Hans": {
