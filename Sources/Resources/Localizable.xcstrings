    "help.interactions.click" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Click the island to cycle through states: Compact → Expanded → Full → Compact."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アイランドをクリックして状態を切り替え：コンパクト → 展開 → フル → コンパクト。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "아일랜드를 클릭하여 상태 전환: 컴팩트 → 확장 → 전체 → 컴팩트."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "点击灵动岛切换状态：紧凑 → 展开 → 完整 → 紧凑。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "點按靈動島切換狀態：緊湊 → 展開 → 完整 → 緊湊。"
          }
        }
      }
    },
    "help.interactions.drag" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Once detached, drag the island to reposition it anywhere on screen."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "切り離した後、アイランドをドラッグして画面上の任意の位置に移動できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "분리 후 아일랜드를 드래그하여 화면 어디든 위치를 변경할 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "脱离后可拖拽灵动岛至屏幕任意位置。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "脫離後可拖曳靈動島至螢幕任意位置。"
          }
        }
      }
    },
    "help.interactions.longpress" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Long-press (hold for 0.5s) the island to detach it from the menu bar and unlock dragging."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アイランドを長押し（0.5秒）するとメニューバーから切り離し、ドラッグが可能になります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "아일랜드를 길게 누르면(0.5초) 메뉴 막대에서 분리되어 드래그할 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "长按灵动岛（按住 0.5 秒）可将其从菜单栏脱离，解锁拖拽功能。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "長按靈動島（按住 0.5 秒）可將其從選單列脫離，解鎖拖曳功能。"
          }
        }
      }
    },
    "help.interactions.snap" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drag the island back near the top of the screen to snap it back to the menu bar."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アイランドを画面上部付近にドラッグすると、メニューバーに再び固定されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "아일랜드를 화면 상단 근처로 드래그하면 메뉴 막대에 다시 부착됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将灵动岛拖拽至屏幕顶部附近即可自动吸附回菜单栏。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "將靈動島拖曳至螢幕頂部附近即可自動吸附回選單列。"
          }
        }
      }
    },
    "help.providers.chain" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lyrics are fetched from multiple sources in order: LRCLIB → Musixmatch → Soda Music → Netease. The first source that returns synced lyrics wins."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "歌詞は複数のソースから順番に取得されます：LRCLIB → Musixmatch → Soda Music → Netease。最初に同期歌詞を返したソースが使用されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "가사는 여러 소스에서 순서대로 가져옵니다: LRCLIB → Musixmatch → Soda Music → Netease. 싱크 가사를 먼저 반환하는 소스가 사용됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "歌词按优先级依次从多个来源获取：LRCLIB → Musixmatch → 汽水音乐 → 网易云。首个返回同步歌词的来源将被采用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "歌詞依優先順序從多個來源取得：LRCLIB → Musixmatch → 汽水音樂 → 網易雲。首個回傳同步歌詞的來源將被採用。"
          }
        }
      }
    },
