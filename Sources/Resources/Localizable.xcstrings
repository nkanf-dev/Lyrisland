          }
        }
      }
    },
    "help.settings.offset": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lyrics Offset — adjust timing offset when lyrics are out of sync. Use ±0.5s buttons or ⌘[ / ⌘] shortcuts."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "歌词偏移 — 当歌词不同步时调整时间偏移。可使用 ±0.5 秒按钮或 ⌘[ / ⌘] 快捷键。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "歌詞偏移 — 當歌詞不同步時調整時間偏移。可使用 ±0.5 秒按鈕或 ⌘[ / ⌘] 快捷鍵。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "歌詞オフセット — 歌詞がずれている場合にタイミングを調整します。±0.5秒ボタンまたは ⌘[ / ⌘] ショートカットを使用。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "가사 오프셋 — 가사가 맞지 않을 때 타이밍을 조정합니다. ±0.5초 버튼 또는 ⌘[ / ⌘] 단축키를 사용하세요."
          }
        }
      }
    },
