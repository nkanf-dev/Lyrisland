    "onboarding.permission": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Automation Permission"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自动化权限"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "自動化權限"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オートメーション権限"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "자동화 권한"
          }
        }
      }
    },
    "onboarding.permission.desc": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS requires your approval to let this app communicate with Spotify."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS 需要你的授权，以便本应用与 Spotify 通信。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS 需要您的授權，以便本應用程式與 Spotify 通訊。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアプリが Spotify と通信するには、macOS の許可が必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 앱이 Spotify와 통신하려면 macOS 승인이 필요합니다."
          }
        }
      }
    },
    "onboarding.permission.guide": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When prompted, click \"OK\" to grant Automation access. You can also enable it in System Settings → Privacy & Security → Automation."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "出现提示时，点击「好」授予自动化权限。你也可以在系统设置 → 隐私与安全性 → 自动化中手动开启。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "出現提示時，點按「好」授予自動化權限。您也可以在系統設定 → 隱私權與安全性 → 自動化中手動開啟。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロンプトが表示されたら「OK」をクリックしてオートメーションアクセスを許可してください。システム設定 → プライバシーとセキュリティ → オートメーションからも有効にできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메시지가 표시되면 \"확인\"을 클릭하여 자동화 접근 권한을 부여하세요. 시스템 설정 → 개인정보 보호 및 보안 → 자동화에서도 활성화할 수 있습니다."
          }
        }
      }
    },
    "onboarding.permission.granted": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Permission granted"
          }
        },
        "zh-Hans": {
