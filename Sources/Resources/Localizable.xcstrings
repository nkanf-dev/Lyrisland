    "onboarding.tip.offset": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press [ ] to adjust lyrics timing offset"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按 [ ] 键微调歌词时间偏移"
