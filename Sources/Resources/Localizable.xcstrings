    "help.section.interactions": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Island Interactions"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "灵动岛交互"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "靈動島互動"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アイランドの操作"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아일랜드 상호작용"
          }
        }
      }
    },
    "help.interactions.click": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click the island to cycle through states: Compact → Expanded → Full → Compact."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击灵动岛切换状态：紧凑 → 展开 → 完整 → 紧凑。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點按靈動島切換狀態：緊湊 → 展開 → 完整 → 緊湊。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アイランドをクリックして状態を切り替え：コンパクト → 展開 → フル → コンパクト。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아일랜드를 클릭하여 상태 전환: 컴팩트 → 확장 → 전체 → 컴팩트."
          }
        }
      }
    },
    "help.interactions.longpress": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Long-press (hold for 0.5s) the island to detach it from the menu bar and unlock dragging."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "长按灵动岛（按住 0.5 秒）可将其从菜单栏脱离，解锁拖拽功能。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "長按靈動島（按住 0.5 秒）可將其從選單列脫離，解鎖拖曳功能。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アイランドを長押し（0.5秒）するとメニューバーから切り離し、ドラッグが可能になります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아일랜드를 길게 누르면(0.5초) 메뉴 막대에서 분리되어 드래그할 수 있습니다."
          }
        }
      }
    },
    "help.interactions.drag": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Once detached, drag the island to reposition it anywhere on screen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "脱离后可拖拽灵动岛至屏幕任意位置。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "脫離後可拖曳靈動島至螢幕任意位置。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "切り離した後、アイランドをドラッグして画面上の任意の位置に移動できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "분리 후 아일랜드를 드래그하여 화면 어디든 위치를 변경할 수 있습니다."
          }
        }
      }
    },
    "help.interactions.snap": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag the island back near the top of the screen to snap it back to the menu bar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将灵动岛拖拽至屏幕顶部附近即可自动吸附回菜单栏。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將靈動島拖曳至螢幕頂部附近即可自動吸附回選單列。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アイランドを画面上部付近にドラッグすると、メニューバーに再び固定されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아일랜드를 화면 상단 근처로 드래그하면 메뉴 막대에 다시 부착됩니다."
          }
        }
      }
    },
    "help.section.settings": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Settings"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置说明"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "設定說明"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정"
          }
        }
      }
    },
    "help.settings.position": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Position Mode — switch between Attached (pinned to menu bar) and Detached (free-floating) modes."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "位置模式 — 在吸附（固定于菜单栏）和自由（浮动拖拽）模式之间切换。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "位置模式 — 在吸附（固定於選單列）和自由（浮動拖曳）模式之間切換。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "位置モード — 固定（メニューバーに固定）とフリー（自由移動）モードを切り替えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "위치 모드 — 부착(메뉴 막대에 고정)과 분리(자유 이동) 모드를 전환합니다."
          }
        }
      }
    },
    "help.settings.artwork": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Show Artwork — display album cover art alongside lyrics in the island."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示专辑封面 — 在灵动岛中展示当前播放歌曲的封面图片。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "顯示專輯封面 — 在靈動島中展示當前播放歌曲的封面圖片。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アートワーク表示 — アイランドに歌詞と一緒にアルバムカバーを表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아트워크 표시 — 아일랜드에 가사와 함께 앨범 커버를 표시합니다."
          }
        }
      }
    },
    "help.settings.dualline": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dual-Line Mode — show the current lyric line and the next line together."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "双行模式 — 同时显示当前歌词和下一行歌词。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "雙行模式 — 同時顯示當前歌詞和下一行歌詞。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "2行モード — 現在の歌詞行と次の行を同時に表示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "2줄 모드 — 현재 가사와 다음 줄을 함께 표시합니다."
          }
        }
      }
    },
    "help.settings.alignment": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lyrics Alignment — choose left, center, or right alignment for lyrics text."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "歌词对齐 — 选择歌词文本的对齐方式：左对齐、居中或右对齐。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
