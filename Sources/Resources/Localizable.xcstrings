    "onboarding.spotify.install_hint": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please install the Spotify desktop app first."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先安装 Spotify 桌面客户端。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
