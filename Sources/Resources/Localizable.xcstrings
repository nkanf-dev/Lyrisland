    "onboarding.subtitle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Desktop lyrics in a Dynamic Island"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "灵动岛桌面歌词"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "靈動島桌面歌詞"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダイナミックアイランドでデスクトップ歌詞を表示"
