    "onboarding.permission.pending": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Permission will be requested when Spotify is accessed"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "访问 Spotify 时将请求权限"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "存取 Spotify 時將請求權限"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Spotify へのアクセス時に権限がリクエストされます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Spotify에 접근할 때 권한이 요청됩니다"
          }
        }
      }
    },
    "onboarding.ready": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You're all set!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一切就绪！"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "一切就緒！"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "準備完了！"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 준비가 완료되었습니다!"
          }
        }
      }
    },
    "onboarding.tip.click": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click the island to expand/collapse lyrics"
          }
        },
        "zh-Hans": {
