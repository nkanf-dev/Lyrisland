    "onboarding.spotify.launch_hint": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Launch Spotify and play a song to get started."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启动 Spotify 并播放一首歌曲即可开始。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "啟動 Spotify 並播放一首歌曲即可開始。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
