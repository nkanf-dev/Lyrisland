    "help.settings.alignment" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lyrics Alignment — choose left, center, or right alignment for lyrics text."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "歌詞の配置 — 歌詞テキストの左揃え、中央揃え、右揃えを選択します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "가사 정렬 — 가사 텍스트의 왼쪽, 가운데, 오른쪽 정렬을 선택합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "歌词对齐 — 选择歌词文本的对齐方式：左对齐、居中或右对齐。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "歌詞對齊 — 選擇歌詞文字的對齊方式：靠左、置中或靠右。"
          }
        }
      }
    },
    "help.settings.artwork" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Show Artwork — display album cover art alongside lyrics in the island."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アートワーク表示 — アイランドに歌詞と一緒にアルバムカバーを表示します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "아트워크 표시 — 아일랜드에 가사와 함께 앨범 커버를 표시합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "显示专辑封面 — 在灵动岛中展示当前播放歌曲的封面图片。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "顯示專輯封面 — 在靈動島中展示當前播放歌曲的封面圖片。"
          }
        }
      }
    },
    "help.settings.dualline" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dual-Line Mode — show the current lyric line and the next line together."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "2行モード — 現在の歌詞行と次の行を同時に表示します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "2줄 모드 — 현재 가사와 다음 줄을 함께 표시합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "双行模式 — 同时显示当前歌词和下一行歌词。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "雙行模式 — 同時顯示當前歌詞和下一行歌詞。"
          }
        }
      }
    },
    "help.settings.offset" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lyrics Offset — adjust timing offset when lyrics are out of sync. Use ±0.5s buttons or ⌘[ / ⌘] shortcuts."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "歌詞オフセット — 歌詞がずれている場合にタイミングを調整します。±0.5秒ボタンまたは ⌘[ / ⌘] ショートカットを使用。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "가사 오프셋 — 가사가 맞지 않을 때 타이밍을 조정합니다. ±0.5초 버튼 또는 ⌘[ / ⌘] 단축키를 사용하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "歌词偏移 — 当歌词不同步时调整时间偏移。可使用 ±0.5 秒按钮或 ⌘[ / ⌘] 快捷键。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "歌詞偏移 — 當歌詞不同步時調整時間偏移。可使用 ±0.5 秒按鈕或 ⌘[ / ⌘] 快捷鍵。"
          }
        }
      }
    },
    "help.settings.position" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Position Mode — switch between Attached (pinned to menu bar) and Detached (free-floating) modes."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "位置モード — 固定（メニューバーに固定）とフリー（自由移動）モードを切り替えます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "위치 모드 — 부착(메뉴 막대에 고정)과 분리(자유 이동) 모드를 전환합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "位置模式 — 在吸附（固定于菜单栏）和自由（浮动拖拽）模式之间切换。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "位置模式 — 在吸附（固定於選單列）和自由（浮動拖曳）模式之間切換。"
          }
        }
      }
    },
